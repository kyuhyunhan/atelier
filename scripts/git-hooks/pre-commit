#!/usr/bin/env bash
# atelier pre-commit PII guard.
#
# Reads regex patterns from ~/.atelier/pii_patterns.txt (one per line,
# blank lines and # comments ignored) and rejects the commit if any
# staged addition matches.
#
# The patterns file itself is out of tree (user-private). This hook
# script is in the repo so anyone installing atelier inherits the
# guard, but the patterns are personal to each user.

set -u

PATTERN_FILE="$HOME/.atelier/pii_patterns.txt"

if [ ! -f "$PATTERN_FILE" ]; then
  echo "atelier pre-commit: $PATTERN_FILE not found; skipping PII scan." >&2
  exit 0
fi

files=$(git diff --cached --name-only --diff-filter=ACM)
if [ -z "$files" ]; then
  exit 0
fi

violations=0
while IFS= read -r pattern || [ -n "$pattern" ]; do
  [ -z "$pattern" ] && continue
  case "$pattern" in \#*) continue ;; esac

  # Scan only the *added* lines in the staged diff.
  matches=$(git diff --cached -U0 -- $files \
            | grep -E '^\+' \
            | grep -E "$pattern" \
            | head -5 || true)
  if [ -n "$matches" ]; then
    echo "atelier pre-commit: PII pattern matched: $pattern" >&2
    echo "$matches" | sed 's/^/  | /' >&2
    violations=$((violations + 1))
  fi
done < "$PATTERN_FILE"

if [ "$violations" -gt 0 ]; then
  echo "" >&2
  echo "Commit blocked. Remove the PII, or update $PATTERN_FILE" >&2
  echo "if the match is intentional." >&2
  exit 1
fi

exit 0
